{
  "expo": {
    "name": "runcool",
    "slug": "runcool",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "runcool",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.matteobruno5.runcool"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "RunCool",
      "shortName": "RunCool",
      "description": "Corri birresponsabilmente 🐷",
      "themeColor": "#FFD700",
      "backgroundColor": "#111111",
      "lang": "it",
      "display": "standalone"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "expo-font",
      "expo-web-browser"
    ],
    "updates": {
      "url": "https://u.expo.dev/730ff266-09d0-4b0a-94b0-9891663f40aa"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "730ff266-09d0-4b0a-94b0-9891663f40aa"
      }
    },
    "owner": "matteobruno5"
  }
}
